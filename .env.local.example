# Copy to .env.local and fill in real values. .env.local is gitignored.

# Public site URL — used by metadataBase, OG, sitemap, robots, JSON-LD.
# In production set this to https://adowlz.com.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (https://resend.com) — used by /api/contact to send the contact form.
# Free tier: 100 emails/day. Leave blank in dev to log submissions instead of sending.
RESEND_API_KEY=
# The address that receives contact-form submissions.
CONTACT_TO_EMAIL=hello@adowlz.com
# The verified sender domain in Resend (e.g. no-reply@adowlz.com).
CONTACT_FROM_EMAIL=

# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX. Leave blank to disable.
NEXT_PUBLIC_GA_ID=
